# ═══════════════════════════════════════════════════
#  BARBERSHOPNEARME — Frontend Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════

# ── API Base URL ─────────────────────────────────────
# LOCAL: leave blank — Vite dev proxy handles /api → localhost:8000
# PRODUCTION: set to your Railway backend URL, e.g.:
# VITE_API_BASE_URL=https://barbershopnearme-backend.up.railway.app/api
VITE_API_BASE_URL=
