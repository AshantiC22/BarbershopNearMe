# ═══════════════════════════════════════════════════
#  BARBERSHOPNEARME — Backend Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-50-char-string
DEBUG=True

# ── Database ────────────────────────────────────────
# Railway auto-sets this when you add a Postgres plugin.
# Local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/barbershopnearme
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ── URLs (update after deploying) ───────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── Email (SendGrid) ────────────────────────────────
# Get your API key at: https://app.sendgrid.com/settings/api_keys
# Sender must be a verified sender identity in SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=Barbershopnearme <noreply@barbershopnearme.com>

# ── SMS (Twilio) — optional ──────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+16015550199
# TWILIO_DEMO_NUMBER=+1YOUR_VERIFIED_NUMBER  # only needed on Twilio trial

# ── Stripe — optional, for online payments ──────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_CONNECT_CLIENT_ID=ca_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Barber Invite Code ───────────────────────────────
BARBER_INVITE_CODE=BSNM2026
