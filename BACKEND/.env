# ═══════════════════════════════════════════════════
#  BARBERSHOPNEARME — Backend Environment Variables
#  Copy this to .env and fill in your real values.
#  Never commit .env to git.
# ═══════════════════════════════════════════════════
BARBER_INVITE_CODE=BSNM2026
# ── Django ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-50-chars-minimum
DEBUG=False

# ── Database (PostgreSQL) ────────────────────────────
# Railway auto-sets this when you add a Postgres plugin.
# Local: postgresql://postgres:password@localhost:5432/barbershopnearme
DATABASE_URL=postgresql://postgres:Cocroft5!@localhost:5432/barbershopnearme

# ── URLs ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── Email (SendGrid) ─────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=noreply@barbershopnearme.com

# ── SMS (Twilio) — optional ───────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+16015550199

# ── Stripe — optional, needed for deposits ───────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY_LIVE=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY_TEST=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_CONNECT_CLIENT_ID=ca_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_MODE=test
